<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="UBB_SE_2026_Jobs.App.Views.TestsAndInterviews.TiRecruiterInterviewsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dtos="using:UBB_SE_2026_Jobs.App.Dtos.TI"
    xmlns:converters="using:UBB_SE_2026_Jobs.App.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <converters:StatusToColorConverter x:Key="StatusToColor"/>
        <converters:StatusToVisibilityConverter x:Key="StatusToVisibility"/>
        <converters:DateTimeToStringConverter x:Key="DateTimeToString"/>
    </Page.Resources>

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="Booked Interviews" FontSize="24" FontWeight="Bold"/>
                <TextBlock Text="All scheduled interview sessions assigned to you."
                           FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
            <Button Grid.Column="1"
                    Content="Manage Slots"
                    VerticalAlignment="Center"
                    Click="ManageSlots_Click"/>
        </Grid>

        <!-- Empty state -->
        <Border Grid.Row="1"
                Background="#F0EEFF"
                CornerRadius="8"
                Padding="32"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay}">
            <TextBlock Text="No interviews have been booked yet."
                       HorizontalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Border>

        <!-- Interviews list -->
        <ScrollViewer Grid.Row="1"
                      Visibility="{x:Bind ViewModel.HasSessions, Mode=OneWay}"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="0">
                <!-- Table header -->
                <Border Background="#F0EEFF" CornerRadius="8,8,0,0" Padding="12,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="#" FontWeight="SemiBold" FontSize="13"/>
                        <TextBlock Grid.Column="1" Text="Candidate" FontWeight="SemiBold" FontSize="13"/>
                        <TextBlock Grid.Column="2" Text="Position" FontWeight="SemiBold" FontSize="13"/>
                        <TextBlock Grid.Column="3" Text="Date &amp; Time" FontWeight="SemiBold" FontSize="13"/>
                        <TextBlock Grid.Column="4" Text="Status" FontWeight="SemiBold" FontSize="13"/>
                        <TextBlock Grid.Column="5" Text="Actions" FontWeight="SemiBold" FontSize="13"/>
                    </Grid>
                </Border>

                <!-- Rows -->
                <ItemsRepeater ItemsSource="{x:Bind ViewModel.BookedSessions, Mode=OneWay}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="dtos:TiInterviewSessionDto">
                            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="12,14">
                                <Grid VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="140"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{x:Bind Id}"
                                               VerticalAlignment="Center" FontSize="13"/>

                                    <TextBlock Grid.Column="1"
                                               VerticalAlignment="Center" FontSize="13">
                                        <Run Text="Candidate #"/>
                                        <Run Text="{x:Bind ExternalUserId}"/>
                                    </TextBlock>

                                    <TextBlock Grid.Column="2"
                                               VerticalAlignment="Center" FontSize="13">
                                        <Run Text="Position #"/>
                                        <Run Text="{x:Bind PositionId}"/>
                                    </TextBlock>

                                    <TextBlock Grid.Column="3"
                                               Text="{x:Bind DateStart, Converter={StaticResource DateTimeToString}}"
                                               VerticalAlignment="Center" FontSize="13"/>

                                    <Border Grid.Column="4"
                                            Background="{x:Bind Status, Converter={StaticResource StatusToColor}}"
                                            CornerRadius="12" Padding="10,4"
                                            VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <TextBlock Text="{x:Bind Status}"
                                                   Foreground="White"
                                                   FontSize="12" FontWeight="SemiBold"/>
                                    </Border>

                                    <Button Grid.Column="5"
                                            Content="Confirm &amp; Decide"
                                            FontSize="12"
                                            Background="#7C5CFC"
                                            Foreground="White"
                                            VerticalAlignment="Center"
                                            Visibility="{x:Bind Status, Converter={StaticResource StatusToVisibility}}"
                                            Tag="{x:Bind}"
                                            Click="DecideButton_Click"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>