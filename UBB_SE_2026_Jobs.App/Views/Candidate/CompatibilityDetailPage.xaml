<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="UBB_SE_2026_Jobs.App.Views.Candidate.CompatibilityDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:UBB_SE_2026_Jobs.App.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="Page_Loaded">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Grid.Row="0" Content="Back" Click="ButtonBack_Click" Margin="0,0,0,16"/>

        <TextBlock x:Name="roleNameLabel" Grid.Row="1" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <TextBlock x:Name="matchScoreLabel" Grid.Row="2" FontSize="16" Margin="0,0,0,16"/>

        <StackPanel Grid.Row="3" Margin="0,0,0,16">
            <TextBlock Text="Skill Evidence Used" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <ListView x:Name="skillScoresList" MaxHeight="220">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:CompatibilitySkillScoreDisplayItem">
                        <Grid Margin="0,4,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Bind SkillName}" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="{x:Bind ScoreDisplay}"/>
                            <TextBlock Grid.Column="2" Text="{x:Bind Source}" Foreground="Gray" TextWrapping="Wrap"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <TextBlock x:Name="noSkillScoresLabel"
                       Text="No matching profile or test skills were found for this role."
                       Visibility="Collapsed"/>
        </StackPanel>

        <StackPanel Grid.Row="4">
            <TextBlock Text="Top Improvement Suggestions" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <ListView x:Name="suggestionsList">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:SuggestionDisplayItem">
                        <StackPanel Margin="0,4,0,4">
                            <TextBlock Text="{x:Bind SkillName}" FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Bind GroupName}" Foreground="Gray" FontSize="12"/>
                            <TextBlock Text="{x:Bind GainDisplay}" FontSize="12"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <TextBlock x:Name="noSuggestionsLabel"
                       Text="No significant skill gaps found for this role."
                       Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</Page>
