<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="UBB_SE_2026_Jobs.App.Views.Controls.SkillTestCardControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border Background="#f5f0fa" CornerRadius="8" Padding="16,12" Margin="0,4">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="64"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Tier badge -->
            <Border Grid.Column="0"
                    Width="52" Height="52"
                    CornerRadius="8"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <Border.Background>
                    <SolidColorBrush x:Name="TierBackground" Color="#e0d0ee"/>
                </Border.Background>
                <TextBlock x:Name="TierLabel"
                           FontSize="11" FontWeight="SemiBold"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
            </Border>

            <!-- Test info -->
            <StackPanel Grid.Column="1" Margin="16,0" Spacing="2" VerticalAlignment="Center">
                <TextBlock x:Name="TestNameText"
                           FontSize="15" FontWeight="SemiBold"/>
                <TextBlock x:Name="ScoreText"
                           Foreground="Gray" FontSize="12"/>
                <TextBlock x:Name="DateText"
                           Foreground="Gray" FontSize="12"/>
            </StackPanel>

            <!-- Action button -->
            <Button x:Name="ActionButton" Grid.Column="2"
                    Background="#9b72a8" Foreground="White"
                    BorderThickness="0" CornerRadius="6"
                    Padding="14,8"
                    VerticalAlignment="Center"
                    Click="ActionButton_Click"/>
        </Grid>
    </Border>
</UserControl>