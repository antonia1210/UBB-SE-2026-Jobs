<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="UBB_SE_2026_Jobs.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="PussyCats"
    mc:Ignorable="d">

    <NavigationView x:Name="navView"
                    SelectionChanged="NavView_SelectionChanged"
                    BackRequested="NavView_BackRequested"
                    PaneOpened="NavView_PaneOpened"
                    PaneClosed="NavView_PaneClosed"
                    IsBackButtonVisible="Collapsed"
                    PaneDisplayMode="Left"
                    IsSettingsVisible="False">

        <NavigationView.MenuItems>
            <!-- Candidate -->
            <NavigationViewItem Content="Browse Jobs"       Tag="UserRecommendationPage"    Icon="Find"/>
            <NavigationViewItem Content="My Applications"   Tag="UserStatusPage"            Icon="List"/>
            <NavigationViewItem Content="My Profile"        Tag="UserProfilePage"           Icon="Contact"/>
            <NavigationViewItem Content="Test Attempts"      Tag="TestDashboardPage"         Icon="Permissions"/>
            <NavigationViewItem Content="Personality Test"  Tag="PersonalityTestPage"       Icon="Favorite"/>
            <NavigationViewItem Content="Compatibility"     Tag="CompatibilityOverviewPage" Icon="Filter"/>
			<NavigationViewItem Content="Documents"         Tag="DocumentsPage"             Icon="Document"/>
			<!-- Company (hidden until company mode) -->
            <NavigationViewItem x:Name="navRankedApplicants"
                                Content="Ranked Applicants" Tag="CompanyRecommendationPage"
                                Icon="People"               Visibility="Collapsed"/>
            <NavigationViewItem x:Name="navApplicants"
                                Content="Applicants"        Tag="CompanyStatusPage"
                                Icon="Accept"               Visibility="Collapsed"/>
            <!-- Developer -->
            <NavigationViewItem Content="Developer Hub"     Tag="DeveloperPage"
                                Icon="Setting"              Visibility="Collapsed"/>
            <!-- Shared -->
            <NavigationViewItem Content="Chat"              Tag="ChatPage"                  Icon="Message"/>
            <!-- RECRUITMENT & TESTS (shared across all modes) -->
            <NavigationViewItemSeparator/>
            <NavigationViewItemHeader Content="RECRUITMENT &amp; TESTS"/>
            <NavigationViewItem Content="Jobs"          Tag="TiJobsPage"                Icon="Document"/>
            <NavigationViewItem Content="Tests"         Tag="TiMainTestPage"            Icon="Play"/>
            <NavigationViewItem Content="Events"        Tag="TiEventsPage"              Icon="Calendar"/>
            <NavigationViewItem Content="Interviews"    Tag="TiInterviewSlotsPage"      Icon="Clock" Visibility="Collapsed"/>
            <NavigationViewItem Content="My Interviews" Tag="TiRecruiterInterviewsPage" Icon="Video" Visibility="Collapsed"/>
        </NavigationView.MenuItems>

        <NavigationView.FooterMenuItems>
            <NavigationViewItem Content="Logout" Tag="Logout" Icon="Cancel"/>
        </NavigationView.FooterMenuItems>

        <NavigationView.PaneCustomContent>
            <StackPanel x:Name="accountSummary"
                        Margin="12,8"
                        Spacing="2"
                        Visibility="Collapsed">
                <TextBlock Text="Signed in as"
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock x:Name="accountNameText"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="accountModeText"
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </NavigationView.PaneCustomContent>

        <Frame x:Name="contentFrame"/>
    </NavigationView>
</Window>
