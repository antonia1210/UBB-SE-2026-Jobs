@model IReadOnlyList<UBB_SE_2026_Jobs.Library.Domain.Match>
@using UBB_SE_2026_Jobs.Library.DTOs
@using UBB_SE_2026_Jobs.Library.Domain.Enums

@{
    ViewData["Title"] = "Match History";
    var statistics = ViewBag.Statistics as MatchStatistics;
}

<div class="container py-4">

    <h2 class="fw-bold mb-4">Match History</h2>

    <!-- Matches table -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="p-4 text-center text-muted">
                    <p class="mb-0">No matches yet. Apply to jobs to see your history here.</p>
                </div>
            }
            else
            {
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="px-4 py-3">Company Name</th>
                            <th class="px-4 py-3">Job Title</th>
                            <th class="px-4 py-3">Job Role</th>
                            <th class="px-4 py-3">Status</th>
                            <th class="px-4 py-3">Match Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var match in Model)
                        {
                            string statusColor = match.Status switch
                            {
                                MatchStatus.Accepted => "success",
                                MatchStatus.Rejected => "danger",
                                MatchStatus.Applied => "primary",
                                MatchStatus.Advanced => "info",
                                _ => "secondary",
                            };
                            <tr>
                                <td class="px-4 py-3">@(match.Job?.Company?.Name ?? "—")</td>
                                <td class="px-4 py-3">@(match.Job?.JobTitle ?? "—")</td>
                                <td class="px-4 py-3">@(match.Job?.JobRole?.ToString() ?? "—")</td>
                                <td class="px-4 py-3">
                                    <span class="badge bg-@statusColor">@match.Status</span>
                                </td>
                                <td class="px-4 py-3">@match.Timestamp.ToString("dd MMM yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>

    @if (statistics is not null)
    {
        <div class="row g-4">
            <!-- Activity Overview -->
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="fw-semibold mb-3">Activity Overview</h5>
                        <ul class="list-unstyled mb-0">
                            <li class="mb-2 text-muted">
                                Total Matches:
                                <span class="fw-semibold text-dark">@statistics.TotalMatches</span>
                            </li>
                            <li class="mb-2 text-muted">
                                Last Month:
                                <span class="fw-semibold text-dark">@statistics.MatchesLastMonth</span>
                            </li>
                            <li class="mb-2 text-muted">
                                Last 6 Months:
                                <span class="fw-semibold text-dark">@statistics.MatchesLastSixMonths</span>
                            </li>
                            <li class="text-muted">
                                Last Year:
                                <span class="fw-semibold text-dark">@statistics.MatchesLastYear</span>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Matches per Position -->
            <div class="col-md-8">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="fw-semibold mb-3">Matches per Position</h5>
                        @if (statistics.MatchesPerPosition.Any())
                        {
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Job Role</th>
                                        <th>Match Count</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var kvp in statistics.MatchesPerPosition)
                                    {
                                        <tr>
                                            <td>@kvp.Key</td>
                                            <td>@kvp.Value</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <p class="text-muted mb-0">No position data available.</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>