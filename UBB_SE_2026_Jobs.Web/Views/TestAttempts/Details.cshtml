@model UBB_SE_2026_Jobs.Library.DTOs.Web.TestAttemptDto

@{
    ViewData["Title"] = "Test Attempt";
}

<div class="container mt-4">
    <h2>Test Attempt #@Model.Id</h2>

    <div class="mb-3">
        <h5>Answers</h5>

        <form asp-action="SaveAnswers" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="attemptId" value="@Model.Id" />

            @if (Model.Answers != null && Model.Answers.Any())
            {
                <div class="list-group">
                    @for (int answerIndex = 0; answerIndex < Model.Answers.Count; answerIndex++)
                    {
                        var answer = Model.Answers[answerIndex];
                        <div class="list-group-item">
                            <input type="hidden" name="answers[@answerIndex].QuestionId" value="@answer.QuestionId" />
                            <input type="hidden" name="answers[@answerIndex].AttemptId" value="@answer.AttemptId" />

                            <div class="mb-2">
                                <label class="form-label">Question</label>
                                <div class="text-muted">@((answer.Question != null && !string.IsNullOrEmpty(answer.Question.QuestionText)) ? answer.Question.QuestionText : $"Question #{answer.QuestionId}")</div>
                            </div>

                            <div class="mb-2">
                                <label asp-for="Answers[@answerIndex].Value" class="form-label">Your answer</label>
                                <input class="form-control" name="answers[@answerIndex].Value" value="@answer.Value" />
                            </div>
                        </div>
                    }
                </div>

                <!-- Save button removed to prevent editing submissions from this view -->
            }
            else
            {
                <div class="text-muted">No questions or answers available.</div>
            }
        </form>
    </div>
</div>

