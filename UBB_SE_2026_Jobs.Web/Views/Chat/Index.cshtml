@model IReadOnlyList<UBB_SE_2026_Jobs.Library.Domain.Chat>
@using UBB_SE_2026_Jobs.Web.Infrastructure
@{
    ViewData["Title"] = "Messages";
    bool isCompanyMode = (bool)(ViewBag.IsCompanyMode ?? false);
}

<div class="container mt-4">
    <h2 class="mb-3">Messages</h2>

    <div class="mb-3 position-relative">
        @Html.AntiForgeryToken()
        <input id="chatSearch" type="search" class="form-control"
               placeholder="@(isCompanyMode ? "Search co-recruiters to chat with..." : "Search or find a user to chat with...")"
               autocomplete="off" />
        <div id="userSearchResults" class="list-group position-absolute w-100 shadow-sm" style="z-index:1000;display:none;"></div>
    </div>

    @{
        var visible = Model.Where(c => c.SecondUser != null).ToList();
    }

    @if (!visible.Any())
    {
        <div class="alert alert-info" id="emptyState">
            No conversations yet.
            @if (!isCompanyMode)
            {
                <span>Use the search above to start a new chat.</span>
            }
        </div>
    }

    <div class="list-group" id="chatList">
        @foreach (var c in visible)
        {
            var other = c.SecondUser is not null
                ? $"{c.SecondUser.FirstName} {c.SecondUser.LastName}".Trim()
                : c.Company?.Name ?? "Unknown";

            <a asp-action="Show" asp-route-id="@c.ChatId"
               class="list-group-item list-group-item-action d-flex align-items-center gap-3 @(c.IsBlocked ? "list-group-item-warning" : "")"
               data-name="@other.ToLowerInvariant()">
                <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center flex-shrink-0"
                     style="width:42px;height:42px;font-weight:600;font-size:1rem;">
                    @(other.Length > 0 ? other[0].ToString().ToUpperInvariant() : "?")
                </div>
                <div class="flex-grow-1 overflow-hidden">
                    <div class="fw-semibold text-truncate">
                        @other
                        @if (c.IsBlocked)
                        {
                            <span class="badge bg-warning text-dark ms-1">Blocked</span>
                        }
                    </div>
                    <small class="text-muted text-truncate d-block">@c.LastMessageSnippet</small>
                </div>
                <div class="text-end flex-shrink-0">
                    <small class="text-muted d-block">@c.LastMessageTime</small>
                    @if (c.UnreadCount > 0)
                    {
                        <span class="badge bg-primary rounded-pill">@c.UnreadCount</span>
                    }
                </div>
            </a>
        }
    </div>
    <div id="noResults" class="alert alert-info d-none">No conversations match your search.</div>
</div>

@section Scripts {
    <script>
        (function () {
            var input = document.getElementById('chatSearch');
            if (!input) return;

            var items = document.querySelectorAll('#chatList .list-group-item');
            var noResults = document.getElementById('noResults');
            var userResults = document.getElementById('userSearchResults');
            var tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');

            var searchTimer = null;

            input.addEventListener('input', function () {
                var query = this.value.trim();
                var lower = query.toLowerCase();

                // Filter existing chats client-side
                var visibleCount = 0;
                items.forEach(function (item) {
                    var show = !lower || (item.dataset.name || '').includes(lower);
                    item.classList.toggle('d-none', !show);
                    if (show) visibleCount++;
                });
                if (noResults) noResults.classList.toggle('d-none', visibleCount > 0 || !lower);

                // API user search (candidates only)
                if (!userResults || !tokenInput) return;

                clearTimeout(searchTimer);
                if (query.length < 2) {
                    userResults.style.display = 'none';
                    userResults.innerHTML = '';
                    return;
                }

                searchTimer = setTimeout(function () {
                    fetch('/Chat/SearchUsers?q=' + encodeURIComponent(query), {
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    })
                    .then(function (r) { return r.json(); })
                    .then(function (users) {
                        if (!users.length) {
                            userResults.style.display = 'none';
                            userResults.innerHTML = '';
                            return;
                        }
                        var token = tokenInput.value;
                        userResults.innerHTML = users.map(function (u) {
                            return '<button type="button" class="list-group-item list-group-item-action d-flex align-items-center gap-2"'
                                + ' onclick="startUserChat(' + u.id + ')">'
                                + '<div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center flex-shrink-0"'
                                + ' style="width:32px;height:32px;font-size:0.85rem;">'
                                + escapeHtml(u.name.charAt(0).toUpperCase()) + '</div>'
                                + '<span>' + escapeHtml(u.name) + '</span>'
                                + '<small class="text-muted ms-auto">Start chat</small>'
                                + '</button>';
                        }).join('');
                        userResults.style.display = 'block';
                        window.__chatCsrfToken = token;
                    })
                    .catch(function () {
                        userResults.style.display = 'none';
                    });
                }, 300);
            });

            document.addEventListener('click', function (e) {
                if (userResults && !userResults.contains(e.target) && e.target !== input) {
                    userResults.style.display = 'none';
                }
            });

            window.startUserChat = function (userId) {
                var form = document.createElement('form');
                form.method = 'POST';
                form.action = '/Chat/StartChat';
                var t = document.createElement('input');
                t.type = 'hidden';
                t.name = '__RequestVerificationToken';
                t.value = window.__chatCsrfToken || '';
                var id = document.createElement('input');
                id.type = 'hidden';
                id.name = 'targetUserId';
                id.value = userId;
                form.appendChild(t);
                form.appendChild(id);
                document.body.appendChild(form);
                form.submit();
            };

            function escapeHtml(str) {
                return String(str)
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;');
            }
        })();
    </script>
}
