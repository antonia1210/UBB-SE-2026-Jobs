@model IEnumerable<UBB_SE_2026_Jobs.Library.DTOs.UserApplicationResult>

@{
    ViewData["Title"] = "Ranked Applicants";
}

<h1>Ranked Applicants</h1>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success" role="alert">@successMessage</div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

@if (!Model.Any())
{
    <div class="alert alert-info" role="alert">No applied applicants are waiting for review.</div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Applicant</th>
                <th>Job</th>
                <th>Score</th>
                <th>Status</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var applicant in Model)
        {
            <tr>
                <td>
                    <strong>@applicant.User.Name</strong>
                    <div class="text-muted">@applicant.User.Email</div>
                </td>
                <td>
                    <strong>@applicant.Job.JobTitle</strong>
                    <div class="text-muted">@applicant.Job.Company?.Name</div>
                </td>
                <td>@applicant.CompatibilityScore.ToString("F1")</td>
                <td>@applicant.Match.Status</td>
                <td class="text-end">
                    <div class="d-inline-flex flex-wrap justify-content-end gap-2">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@applicant.Match.MatchId">Details</a>
                        <form asp-action="Skip" asp-route-id="@applicant.Match.MatchId" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="returnToDetails" value="false" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">Skip</button>
                        </form>
                        <form asp-action="Advance" asp-route-id="@applicant.Match.MatchId" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="returnToDetails" value="false" />
                            <button type="submit" class="btn btn-sm btn-success">Advance</button>
                        </form>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
