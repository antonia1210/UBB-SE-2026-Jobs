@using System.Globalization
@model CompanyRecommendationDetailsModel

@{
    ViewData["Title"] = "Applicant Recommendation";
    var applicant = Model.Applicant;
    var breakdown = Model.Breakdown;
}

<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h1 class="mb-1">Applicant Recommendation</h1>
        <div class="text-muted">Applied for @Display(applicant.Job.JobTitle, "Untitled job")</div>
    </div>
    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
        <form asp-action="Skip" asp-route-id="@applicant.Match.MatchId" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnToDetails" value="true" />
            <button type="submit" class="btn btn-outline-danger">Skip</button>
        </form>
        <form asp-action="Advance" asp-route-id="@applicant.Match.MatchId" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnToDetails" value="true" />
            <button type="submit" class="btn btn-success">Advance</button>
        </form>
    </div>
</div>

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

<div class="row g-4">
    <div class="col-lg-7">
        <section class="border rounded p-4 mb-4">
            <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
                <div>
                    <h2 class="h4 mb-1">@Display(FormatName(applicant.User), applicant.User.Email)</h2>
                    <div class="text-muted">@Display(applicant.User.Email)</div>
                </div>
                <span class="badge text-bg-success fs-6">@applicant.CompatibilityScore.ToString("F0")% Match</span>
            </div>
        </section>

        <section class="border rounded p-4 mb-4">
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="text-muted small text-uppercase">Location</div>
                    <div class="fw-semibold">@Display(FormatLocation(applicant.User))</div>
                </div>
                <div class="col-md-4">
                    <div class="text-muted small text-uppercase">Years of Experience</div>
                    <div class="fw-semibold">@applicant.User.YearsOfExperience years</div>
                </div>
                <div class="col-md-4">
                    <div class="text-muted small text-uppercase">Education</div>
                    <div class="fw-semibold">@Display(FormatEducation(applicant.User))</div>
                </div>
            </div>
        </section>

        <section class="border rounded p-4 mb-4">
            <h2 class="h6 text-muted text-uppercase">Resume</h2>
            <p class="mb-0 text-break">@Display(FormatResume(applicant.User), "No motivation text provided.")</p>
        </section>

        <section class="border rounded p-4 mb-4">
            <h2 class="h6 text-muted text-uppercase">Job Description</h2>
            <p class="mb-0 text-break">@Display(applicant.Job.JobDescription)</p>
        </section>

        <section class="border rounded p-4">
            <h2 class="h6 text-muted text-uppercase">All Skills</h2>
            @if (!applicant.UserSkills.Any())
            {
                <p class="text-muted mb-0">No skills recorded.</p>
            }
            else
            {
                <div class="vstack gap-3">
                    @foreach (var userSkill in applicant.UserSkills.OrderByDescending(skill => skill.Score))
                    {
                        <div>
                            <div class="d-flex justify-content-between gap-3 mb-1">
                                <span>@userSkill.Skill.Name</span>
                                <span class="fw-semibold">@userSkill.Score</span>
                            </div>
                            <div class="progress" role="progressbar" aria-label="@userSkill.Skill.Name score" aria-valuenow="@userSkill.Score" aria-valuemin="0" aria-valuemax="100" style="height: 8px;">
                                <div class="progress-bar" style="width: @BarWidth(userSkill.Score)"></div>
                            </div>
                        </div>
                    }
                </div>
            }
        </section>
    </div>

    <div class="col-lg-5">
        <section class="border rounded p-4 mb-4">
            <h2 class="h5 mb-3">Compatibility Breakdown</h2>
            @if (breakdown is null)
            {
                <p class="text-muted mb-0">Breakdown is not available.</p>
            }
            else
            {
                <div class="row g-3">
                    <div class="col-sm-6">
                        <div class="text-muted small">Skill Match</div>
                        <div class="fs-5 fw-bold">@breakdown.SkillScore.ToString("F1")</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="text-muted small">Keyword Match</div>
                        <div class="fs-5 fw-bold">@breakdown.KeywordScore.ToString("F1")</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="text-muted small">Preference Match</div>
                        <div class="fs-5 fw-bold">@breakdown.PreferenceScore.ToString("F1")</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="text-muted small">Promotion Score</div>
                        <div class="fs-5 fw-bold">@breakdown.PromotionScore.ToString("F1")</div>
                    </div>
                    <div class="col-12 border-top pt-3">
                        <div class="text-muted small">Overall</div>
                        <div class="fs-4 fw-bold">@breakdown.OverallScore.ToString("F1")</div>
                    </div>
                </div>
            }
        </section>

        <section class="border rounded p-4 mb-4">
            <h2 class="h5 mb-3">Contact</h2>
            <dl class="row mb-0">
                <dt class="col-sm-4">Email</dt>
                <dd class="col-sm-8 text-break">@Display(applicant.User.Email)</dd>

                <dt class="col-sm-4">Phone</dt>
                <dd class="col-sm-8">@Display(applicant.User.Phone)</dd>

                <dt class="col-sm-4">Status</dt>
                <dd class="col-sm-8">@applicant.Match.Status</dd>
            </dl>
        </section>

        <section class="border rounded p-4">
            <h2 class="h5 mb-3">Review Action</h2>
            <div class="d-grid gap-2">
                <form asp-action="Skip" asp-route-id="@applicant.Match.MatchId" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnToDetails" value="true" />
                    <button type="submit" class="btn btn-outline-danger w-100">Skip</button>
                </form>
                <form asp-action="Advance" asp-route-id="@applicant.Match.MatchId" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnToDetails" value="true" />
                    <button type="submit" class="btn btn-success w-100">Advance</button>
                </form>
            </div>
        </section>
    </div>
</div>

@functions {
    private static string Display(string? value, string fallback = "Not provided")
    {
        return string.IsNullOrWhiteSpace(value) ? fallback : value.Trim();
    }

    private static string FormatName(UBB_SE_2026_Jobs.Library.Domain.User user)
    {
        return $"{user.FirstName} {user.LastName}".Trim();
    }

    private static string FormatLocation(UBB_SE_2026_Jobs.Library.Domain.User user)
    {
        return string.Join(", ", new[] { user.City, user.Country }.Where(value => !string.IsNullOrWhiteSpace(value)));
    }

    private static string FormatEducation(UBB_SE_2026_Jobs.Library.Domain.User user)
    {
        return string.Join(", ", new[] { user.Degree, user.University }.Where(value => !string.IsNullOrWhiteSpace(value)));
    }

    private static string FormatResume(UBB_SE_2026_Jobs.Library.Domain.User user)
    {
        return !string.IsNullOrWhiteSpace(user.Motivation) ? user.Motivation : user.ParsedCv;
    }

    private static string BarWidth(int score)
    {
        return $"{Math.Clamp(score, 0, 100).ToString(CultureInfo.InvariantCulture)}%";
    }
}
