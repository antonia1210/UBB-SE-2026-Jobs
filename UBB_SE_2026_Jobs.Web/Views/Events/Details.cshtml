@model UBB_SE_2026_Jobs.Library.DTOs.Web.EventDto

@{
    ViewData["Title"] = Model.Title;
}

<h2>@Model.Title</h2>

<div class="card">
    <div class="card-body">
        <p><strong>Location:</strong> @Model.Location</p>
        <p><strong>Start Date:</strong> @Model.StartDate.ToShortDateString()</p>
        <p><strong>End Date:</strong> @Model.EndDate.ToShortDateString()</p>
        <p><strong>Description:</strong> @Model.Description</p>
        <p><strong>Posted At:</strong> @Model.PostedAt</p>
    </div>
</div>

@{
    var collaborators = ViewBag.Collaborators as List<UBB_SE_2026_Jobs.Library.DTOs.Web.CompanyDto> ?? new List<UBB_SE_2026_Jobs.Library.DTOs.Web.CompanyDto>();
}
@if (collaborators.Any())
{
    <h4 class="mt-4">Collaborators</h4>
    <ul>
        @foreach (var collaborator in collaborators)
        {
            <li>@collaborator.Name</li>
        }
    </ul>
}

<a asp-action="Index" class="btn btn-secondary mt-3">Back to Events</a>
