@model List<UBB_SE_2026_Jobs.Web.Dtos.InterviewSessionDto>

@{
    ViewData["Title"] = "Booked Interviews";
}

<div class="container py-4">

    <div class="mb-4 pb-3 border-bottom d-flex align-items-center justify-content-between">
        <div>
            <h2 class="fw-bold text-dark">Booked Interviews</h2>
            <div class="text-muted small">All scheduled interview sessions assigned to you.</div>
        </div>
        <a asp-action="ManageSlots" class="btn btn-sm btn-outline-primary">
            Manage Slots
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="p-4 rounded text-center" style="background:#F0EEFF;">
            <p class="text-muted mb-0">No interviews have been booked yet.</p>
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead style="background:#F0EEFF;">
                        <tr>
                            <th class="px-4 py-3">#</th>
                            <th class="py-3">Candidate</th>
                            <th class="py-3">Position</th>
                            <th class="py-3">Date &amp; Time</th>
                            <th class="py-3">Status</th>
                            <th class="py-3">Score</th>
                            <th class="py-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var session in Model)
                        {
                            <tr>
                                <td class="px-4">@session.Id</td>
                                <td>
                                    @if (session.ExternalUserId.HasValue)
                                    {
                                        <span>Candidate #@session.ExternalUserId</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>Position #@session.PositionId</td>
                                <td>@session.DateStart.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</td>
                                <td>
                                    @{
                                        string badgeClass = session.Status switch
                                        {
                                            "Scheduled" => "bg-primary",
                                            "Completed" => "bg-success",
                                            "Cancelled" => "bg-danger",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @badgeClass">
                                        @(session.Status ?? "Unknown")
                                    </span>
                                </td>
                                <td>
                                    @if (session.Score.HasValue)
                                    {
                                        <span class="fw-semibold">@session.Score.Value.ToString("0.##")</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td>
                                    @if (session.Status == "Scheduled") {
                                        <button class="btn btn-sm text-white"
                                                style="background:#7C5CFC;white-space:nowrap;"
                                                onclick="openDecisionModal(@session.Id, @(session.ExternalUserId ?? 0), @session.PositionId)">
                                            Confirm & Decide
                                        </button>
                                    } else {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    <!-- Decision modal -->
    <div class="modal fade" id="decisionModal" tabindex="-1">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header" style="background:#F0EEFF;">
                    <h6 class="modal-title fw-bold">Candidate Decision</h6>
                    <button type="button" class="btn-close" onclick="hideDecisionModal()"></button>
                </div>
                <div class="modal-body small">
                    <p>Session <strong id="decisionSessionId"></strong></p>
                    <p>Candidate <strong id="decisionCandidateLabel"></strong></p>
                    <p class="mb-0 text-muted">Choose result for candidate:</p>
                </div>
                <div class="modal-footer gap-2">
                    <button class="btn btn-sm btn-outline-secondary" onclick="hideDecisionModal()">Cancel</button>
                    <form method="post" asp-action="SubmitDecision" asp-controller="Interviews" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="sessionId" id="decisionSessionInput" />
                        <input type="hidden" name="decision" value="Declined" />
                        <button type="submit" class="btn btn-sm btn-danger">Decline</button>
                    </form>
                    <form method="post" asp-action="SubmitDecision" asp-controller="Interviews" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="sessionId" id="decisionSessionInput2" />
                        <input type="hidden" name="decision" value="Accepted" />
                        <button type="submit" class="btn btn-sm btn-success">Accept</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function openDecisionModal(sessionId, candidateId, positionId) {
        document.getElementById('decisionSessionId').textContent     = '#' + sessionId;
        document.getElementById('decisionCandidateLabel').textContent = '#' + candidateId;
        ['decisionSessionInput','decisionSessionInput2'].forEach(id =>
            document.getElementById(id).value = sessionId);
        document.getElementById('decisionModal').classList.add('show');
        document.getElementById('decisionModal').style.display = 'block';
    }

    function hideDecisionModal() {
        document.getElementById('decisionModal').classList.remove('show');
        document.getElementById('decisionModal').style.display = 'none';
    }
</script>