@model SlotDto
@{
    ViewData["Title"] = "Manage Interview Slots";
}

<style>
    .day-cell { height: 52px; vertical-align: top; padding: 3px; cursor: default; }
    .day-cell.empty { cursor: pointer; }
    .day-cell.empty:hover { background: #F0EEFF; }
    .slot-chip {
        display: block; border-radius: 4px; padding: 2px 6px;
        font-size: .75rem; font-weight: 600; cursor: pointer;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .slot-chip.free   { background: #F0EEFF; color: #5038C8; border: 1px solid #C4B5FD; }
    .slot-chip.booked { background: #E8F5E9; color: #2E7D32; border: 1px solid #A5D6A7; }
    .slot-chip.free:hover { background: #DDD6FE; }
</style>

<div class="container py-4">
    <div class="mb-4 pb-3 border-bottom">
        <h2 class="fw-bold text-dark">Manage Interview Slots</h2>
        <div class="text-muted small">Click an empty cell to add a slot. Click a slot to edit or delete it.</div>
    </div>

    <!-- Week navigation -->
    <div class="d-flex align-items-center gap-2 mb-3">
        <button class="btn btn-sm" style="background:#F0EEFF;color:#5038C8;" id="prevWeek">&#8249;</button>
        <span class="fw-semibold" id="weekLabel" style="min-width:180px;text-align:center;"></span>
        <button class="btn btn-sm" style="background:#F0EEFF;color:#5038C8;" id="nextWeek">&#8250;</button>
        <button class="btn btn-sm" style="background:#F0EEFF;color:#5038C8;" id="todayBtn">Today</button>
    </div>

    <!-- Legend -->
    <div class="d-flex gap-3 mb-3 small text-muted">
        <span><span class="badge" style="background:#C4B5FD;">&nbsp;</span> Available</span>
        <span><span class="badge" style="background:#A5D6A7;">&nbsp;</span> Booked</span>
    </div>

    <!-- Calendar -->
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-bordered align-middle mb-0" id="calendarTable">
                <thead style="background:#F0EEFF;" id="calendarHead"></thead>
                <tbody id="calendarBody"></tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="slotModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header" style="background:#F0EEFF;">
                <h6 class="modal-title fw-bold" id="modalTitle">Add Slot</h6>
                <button class="btn-close" onclick="closeModal()"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label small fw-semibold">Date</label>
                    <input type="date" id="slotDate" class="form-control form-control-sm" />
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-semibold">Start Time</label>
                    <input type="time" id="slotTime" class="form-control form-control-sm" step="1800" />
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-semibold">Duration</label>
                    <select id="slotDuration" class="form-select form-select-sm">
                        <option value="60" selected>60 min</option>
                        <option value="90">90 min</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label asp-for="CompanyId" class="form-label small fw-semibold">Company</label>
                    <select asp-for="CompanyId" class="form-select form-select-sm">
                        <option value="">Select company</option>
                        @if (ViewData["Companies"] is List<UBB_SE_2026_Jobs.Library.DTOs.Web.CompanyDto> companies)
                        {
                            foreach (var company in companies)
                            {
                                <option value="@company.CompanyId">@company.Name</option>
                            }
                        }
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-sm btn-outline-secondary" onclick="closeModal()">Cancel</button>
                <button class="btn btn-sm btn-outline-danger" id="modalDelete" style="display:none;">Delete</button>
                <button class="btn btn-sm text-white" style="background:#7C5CFC;" id="modalSave">Save</button>
            </div>
        </div>
    </div>
</div>

<script>
(function () {
    let slots = [], weekStart = getMonday(new Date()), editSlot = null;

    const TIME_ROWS = [];
    for (let hour = 8; hour < 18; hour++) {
        TIME_ROWS.push({ hour, minute: 0 });
        TIME_ROWS.push({ hour, minute: 30 });
    }

    document.getElementById('prevWeek').onclick  = () => { weekStart = addDays(weekStart, -7); render(); };
    document.getElementById('nextWeek').onclick  = () => { weekStart = addDays(weekStart,  7); render(); };
    document.getElementById('todayBtn').onclick  = () => { weekStart = getMonday(new Date()); render(); };
    document.getElementById('modalSave').onclick   = saveSlot;
    document.getElementById('modalDelete').onclick = deleteSlot;

    render();

    async function render() {
        document.getElementById('weekLabel').textContent = fmtShort(weekStart) + ' � ' + fmtShort(addDays(weekStart, 6));
        renderHead();
        await loadSlots();
        renderBody();
    }

    function renderHead() {
        const days = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
        let html = '<tr><th style="width:60px;"></th>';
        for (let dayIndex = 0; dayIndex < 7; dayIndex++) {
            const date = addDays(weekStart, dayIndex);
            const today = sameDay(date, new Date());
            html += `<th class="text-center small${today ? ' fw-bold' : ''}" style="${today ? 'background:#DDD6FE;' : ''}">
                ${days[dayIndex]} ${date.getDate()}
            </th>`;
        }
        html += '</tr>';
        document.getElementById('calendarHead').innerHTML = html;
    }

    function renderBody() {
        let html = '';
        for (const { hour, minute } of TIME_ROWS) {
            html += '<tr>';
            html += `<td class="text-end text-muted small pe-2" style="background:#FAFAFA;white-space:nowrap;">${pad(hour)}:${pad(minute)}</td>`;
            for (let dayIndex = 0; dayIndex < 7; dayIndex++) {
                const date = addDays(weekStart, dayIndex);
                const matchingSlots = slots.filter(slot => {
                    const slotStart = new Date(slot.startTime);
                    return sameDay(slotStart, date) && slotStart.getHours() === hour && slotStart.getMinutes() === minute;
                });
                const empty = matchingSlots.length === 0;
                let slotChips = matchingSlots.map(slot =>
                    `<span class="slot-chip ${slot.status ? 'booked' : 'free'}"
                        onclick="slotClick(event,${slot.id})"
                        title="${slot.status ? 'Booked' : 'Click to edit/delete'}">
                        ${pad(hour)}:${pad(minute)} � ${slot.duration ?? 60}m
                    </span>`
                ).join('');
                html += `<td class="day-cell${empty ? ' empty' : ''}"
                    ${empty ? `onclick="cellClick(event,'${toIso(date)}',${hour},${minute})"` : ''}>${slotChips}</td>`;
            }
            html += '</tr>';
        }
        document.getElementById('calendarBody').innerHTML = html;
    }

    window.closeModal = function () {
        document.getElementById('slotModal').classList.remove('show');
        document.getElementById('slotModal').style.display = 'none';
        editSlot = null;
    }

    async function loadSlots() {
        try {
            const response = await fetch('/Interviews/GetRecruiterSlots');
            if (response.ok) slots = await response.json();
        } catch {}
    }

    async function saveSlot() {
        const date = document.getElementById('slotDate').value;
        const time = document.getElementById('slotTime').value;
        const duration = parseInt(document.getElementById('slotDuration').value);
        const companyId = document.getElementById('CompanyId').value;
        if (!date || !time) return;
        const startTime = date + 'T' + time + ':00';
        try {
            let response;
            if (editSlot) {
                response = await fetch('/Interviews/UpdateRecruiterSlot', { method: 'POST', body: new URLSearchParams({
                    'initialSlot.id': editSlot.id,
                    'initialSlot.startTime': editSlot.startTime,
                    'initialSlot.duration': editSlot.duration ?? 60,
                    'initialSlot.companyId': companyId,
                    startTime, duration
                })});
            } else {
                response = await fetch('/Interviews/CreateRecruiterSlot', { method: 'POST', body: new URLSearchParams({
                    'baseSlot.startTime': startTime,
                    'baseSlot.duration': duration,
                    'baseSlot.companyId': companyId,
                    duration
                })});
            }

            if (!response.ok) {
                let msg = 'Failed to save slot.';
                try { const body = await response.json(); if (body.error) msg = body.error; } catch {}
                showError(msg);
                return;
            }

            closeModal();
            await render();
        } catch (error) {
            showError('An unexpected error occurred.');
        }
    }

    function showError(msg) {
        let element = document.getElementById('slotError');
        if (!element) {
            element = document.createElement('div');
            element.id = 'slotError';
            element.className = 'alert alert-danger alert-dismissible mt-3';
            element.innerHTML = '<button type="button" class="btn-close" onclick="this.parentElement.remove()"></button><span id="slotErrorMsg"></span>';
            document.querySelector('.container.py-4').prepend(element);
        }
        document.getElementById('slotErrorMsg').textContent = msg;
        element.style.display = '';
    }

    async function deleteSlot() {
        if (!editSlot || !confirm('Delete this slot?')) return;
        await fetch('/Interviews/DeleteRecruiterSlot', { method: 'POST', body: new URLSearchParams({ id: editSlot.id }) });

        closeModal();
        await render();
    }

    window.cellClick = function (event, isoDate, hour, minute) {
        event.stopPropagation();
        editSlot = null;
        document.getElementById('modalTitle').textContent = 'Add Slot';
        document.getElementById('slotDate').value         = isoDate;
        document.getElementById('slotTime').value         = `${pad(hour)}:${pad(minute)}`;
        document.getElementById('slotDuration').value     = '60';
        document.getElementById('modalDelete').style.display = 'none';
        document.getElementById('modalSave').textContent  = 'Add Slot';

        document.getElementById('slotModal').classList.add('show');
        document.getElementById('slotModal').style.display = 'block';

        const firstOption = document.getElementById('CompanyId').options[1];
        if (firstOption) document.getElementById('CompanyId').value = firstOption.value;
    };

    window.slotClick = function (event, slotId) {
        event.stopPropagation();
        const slot = slots.find(currentSlot => currentSlot.id === slotId);
        if (!slot || slot.status) return;
        editSlot = slot;
        const slotStart = new Date(slot.startTime);
        document.getElementById('modalTitle').textContent = 'Edit Slot';
        document.getElementById('slotDate').value         = toIso(slotStart);
        document.getElementById('slotTime').value         = `${pad(slotStart.getHours())}:${pad(slotStart.getMinutes())}`;
        document.getElementById('slotDuration').value     = slot.duration ?? 60;
        document.getElementById('modalDelete').style.display = '';
        document.getElementById('modalSave').textContent  = 'Update';

        document.getElementById('slotModal').classList.add('show');
        document.getElementById('slotModal').style.display = 'block';

        document.getElementById('CompanyId').value = slot.companyId ?? '';
    };

    function getMonday(date) {
        const diff = date.getDay() === 0 ? -6 : 1 - date.getDay();
        return new Date(date.getFullYear(), date.getMonth(), date.getDate() + diff);
    }
    function addDays(date, numberOfDays) { return new Date(date.getFullYear(), date.getMonth(), date.getDate() + numberOfDays); }
    function sameDay(firstDate, secondDate) { return firstDate.getFullYear()===secondDate.getFullYear() && firstDate.getMonth()===secondDate.getMonth() && firstDate.getDate()===secondDate.getDate(); }
    function pad(value)         { return String(value).padStart(2, '0'); }
    function toIso(date)       { return `${date.getFullYear()}-${pad(date.getMonth()+1)}-${pad(date.getDate())}`; }
    function fmtShort(date)    { return date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' }); }
})();
</script>
