@using UBB_SE_2026_Jobs.Library.Domain
@using UBB_SE_2026_Jobs.Library.Domain.Enums
@using UBB_SE_2026_Jobs.Web.Dtos
@model IReadOnlyList<Match>

@{
    ViewData["Title"] = "Applicants";
    var job = ViewBag.Job as JobPostingDto;
}

<div class="mb-3">
    <a asp-action="Details" asp-controller="Jobs" asp-route-id="@job?.JobId" class="btn btn-outline-secondary btn-sm">&larr; Back to Job</a>
</div>

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div>
            <h2 class="mb-0">Applicants for: @job?.JobTitle</h2>
            <small class="text-muted">@(Model?.Count ?? 0) application@((Model?.Count ?? 0) != 1 ? "s" : "")</small>
        </div>
    </div>
    <div class="card-body">
        @if (Model == null || Model.Count == 0)
        {
            <div class="alert alert-info">
                <p class="mb-0">No applications have been received for this job yet.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Candidate</th>
                            <th>Email</th>
                            <th>Applied</th>
                            <th>Status</th>
                            <th>Feedback</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var match in Model)
                        {
                            var candidateName = $"{match.User?.FirstName} {match.User?.LastName}".Trim();
                            if (string.IsNullOrWhiteSpace(candidateName)) candidateName = $"User {match.User?.UserId}";

                            var badgeClass = match.Status switch
                            {
                                MatchStatus.Accepted => "bg-success",
                                MatchStatus.Rejected => "bg-danger",
                                MatchStatus.Advanced => "bg-primary",
                                _ => "bg-secondary"
                            };

                            <tr>
                                <td>@candidateName</td>
                                <td>@match.User?.Email</td>
                                <td>@match.Timestamp.ToString("dd MMM yyyy HH:mm")</td>
                                <td><span class="badge @badgeClass">@match.Status</span></td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(match.FeedbackMessage))
                                    {
                                        <span class="text-muted small">@match.FeedbackMessage</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
