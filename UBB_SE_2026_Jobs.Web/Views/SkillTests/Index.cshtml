@model IReadOnlyList<UBB_SE_2026_Jobs.Library.DTOs.SkillTestViewDto>
@using UBB_SE_2026_Jobs.Library.Services

@{
    ViewData["Title"] = "Test Attempts";
}

<section class="page-shell skill-tests">
    <header class="skill-tests__hero">
        <div>
            <p class="eyebrow">Assessment Center</p>
            <h1 class="page-title">Test Attempts</h1>
            <p class="page-subtitle">Your test history — see scores for every attempt you have submitted.</p>
        </div>
        <div class="skill-tests__hero-badge">
            <span class="badge-label">Your Progress</span>
            <span class="badge-value">@Model.Count()</span>
            <span class="badge-caption">attempts logged</span>
        </div>
    </header>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="skill-tests__grid">
        @if (!Model.Any())
        {
            <div class="empty-state">
                <h3>No tests yet</h3>
                <p>Once you complete a skill test it will show up here with score history and retake status.</p>
            </div>
        }
        else
        {
            foreach (var test in Model)
            {
                await Html.RenderPartialAsync("SkillTestCard", test);
            }
        }
    </div>
</section>
